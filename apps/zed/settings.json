{
  "cli_default_open_behavior": "existing_window",
  "telemetry": {
    "diagnostics": true,
    "metrics": false
  },
  "session": {
    "trust_all_worktrees": true
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 500
    }
  },
  "agent": {
    "tool_permissions": {
      "default": "allow"
    },
    "play_sound_when_agent_done": "always"
  },
  "vim_mode": true,
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  }
}
